{
  "manifest_version": 3,
  "name": "BookMark - Smart Bookmark Manager",
  "version": "0.1.0",
  "description": "One-click save with AI-powered summarization and tagging",
  "permissions": ["activeTab", "tabs"],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
